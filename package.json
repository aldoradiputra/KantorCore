{
  "name": "kantr",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "dev:roadmap":   "turbo dev --filter=@kantorcore/roadmap",
    "build:roadmap": "turbo build --filter=@kantorcore/roadmap",
    "dev:marketing":   "turbo dev --filter=@kantorcore/marketing",
    "build:marketing": "turbo build --filter=@kantorcore/marketing",
    "dev:docs":   "turbo dev --filter=@kantorcore/docs",
    "build:docs": "turbo build --filter=@kantorcore/docs",
    "dev:web":   "turbo dev --filter=@kantorcore/web",
    "build:web": "turbo build --filter=@kantorcore/web",
    "db:generate": "pnpm --filter=@kantorcore/db db:generate",
    "db:migrate":  "pnpm --filter=@kantorcore/db db:migrate",
    "db:push":     "pnpm --filter=@kantorcore/db db:push",
    "db:studio":   "pnpm --filter=@kantorcore/db db:studio",
    "auth:build":  "pnpm --filter=@kantorcore/auth build",
    "auth:check":  "pnpm --filter=@kantorcore/auth typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@10.33.0"
}
